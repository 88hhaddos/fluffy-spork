# Telegram Bot Token (получить у @BotFather)
BOT_TOKEN=your_telegram_bot_token_here

# ID администраторов через запятую (узнать у @userinfobot)
ADMIN_IDS=123456789,987654321

# Путь к базе данных (опционально, по умолчанию bot.db)
# DB_PATH=bot.db

# Провайдер AI по умолчанию (опционально, можно добавить через админ-меню)
# NVIDIA NIM текст (бесплатно, 1000 кредитов на build.nvidia.com):
# DEFAULT_PROVIDER_URL=https://integrate.api.nvidia.com/v1
# DEFAULT_PROVIDER_KEY=nvapi-xxxxxxxxxxxx
# DEFAULT_PROVIDER_MODEL=nvidia/llama-3.1-nemotron-70b-instruct

# Image-провайдер (опционально, добавьте через админ-меню):
# DEFAULT_IMAGE_PROVIDER_URL=https://your-image-api.com/v1
# DEFAULT_IMAGE_PROVIDER_KEY=your_key
# DEFAULT_IMAGE_PROVIDER_MODEL=your-model

# База данных (опционально):
# Локально: не указывайте DATABASE_URL → используется SQLite (bot.db)
# Railway: добавьте PostgreSQL plugin → Railway сам установит DATABASE_URL
# DATABASE_URL=postgresql://user:pass@host:port/railway

# SStats Football API (ключ уже встроён, можно поменять):
# SSTATS_API_KEY=sjzgn3bbco67pk8j

# Авто-ставки (опционально):
# BETTING_ENABLED=1
# BETTING_CHAT_ID=-1001234567890  (ID чата куда бот будет постить ставки)
